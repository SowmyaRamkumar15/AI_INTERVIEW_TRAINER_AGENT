PORT=8080

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/ai_interview_trainer?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

# Custom App Properties (JWT & File Upload)
JWT_SECRET=your_jwt_secret_key_here_must_be_long_enough
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
FILE_UPLOAD_DIR=uploads/resumes/

# IBM watsonx.ai + Orchestrate Integration
WATSONX_API_KEY=your_watsonx_api_key
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2
WATSONX_ORCHESTRATE_API_KEY=your_orchestrate_api_key
WATSONX_ORCHESTRATE_INSTANCE_ID=your_orchestrate_instance_id
WATSONX_ORCHESTRATE_REGION=eu-gb
WATSONX_ORCHESTRATE_AGENT_ID=your_orchestrate_agent_id
WATSONX_ORCHESTRATE_BASE_DOMAIN=watson-orchestrate.cloud.ibm.com
WATSONX_CHAT_PRIVATE_KEY="your_watsonx_chat_private_key"

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
